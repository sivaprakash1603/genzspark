## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## See https://learn.microsoft.com/dotnet/core/tools/dotnet-gitignore-spec

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (DotSettings)
*.DotSettings.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Log]
[Ll]og/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create the TestResults folder
#TestResults/

# MSTest test Results
[Tt]est[Rr]esults/
[Bb]uild[Ll]og.htm

# NUnit VS Toolkit files
*.VisualState.xml
TestResult.xml

# BuildLogs directory
BuildLog.htm

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Code project settings
.vscode/

# LogicApps temporary files
artifacts/
.temp/

# JetBrains Rider
.idea/

# General
.DS_Store
.env
.env.local
.env.*.local

# Entity Framework migrations (optional: keep if you want to track migrations)
# *.designer.cs

# Publish output
publish/
