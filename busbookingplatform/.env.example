# Backend JWT
JWT_ISSUER=BusBooking.Api
JWT_AUDIENCE=BusBooking.Client
JWT_SECRET=replace-with-long-secret
JWT_EXPIRY_MINUTES=120

# Admin bootstrap (auto-created on startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@busbooking.local

# PostgreSQL
CONNECTIONSTRINGS__DEFAULTCONNECTION=Host=localhost;Port=5432;Database=busbooking;Username=postgres;Password=SiVa@30$

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=smtp-user
SMTP_PASSWORD=smtp-password
SMTP_FROM_EMAIL=noreply@busbooking.com
SMTP_FROM_NAME=Bus Booking
SMTP_USE_SSL=true

# Pricing
PLATFORM_FEE_DEFAULT=20
